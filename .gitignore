Thumbs.db
ehthumbs.db
Desktop.ini

# ── Éditeurs et IDE ───────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-workspace
*.swp
*.swo
*~

# ── Archives et sauvegardes ───────────────────────────────────────────────
*.zip
*.tar.gz
*.bak
*.orig
